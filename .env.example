APP_NAME=EKG Agent Refactor
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8010
DATA_DIR=./data
SQLITE_DB_PATH=./data/components.db
ONTOLOGY_JSON_PATH=./data/ontology_graph.json
VERSION_DIR=./data/versions
SECURITY_AUDIT_LOG=./data/audit/security_audit.jsonl
SECURITY_SECRET=replace-with-strong-secret
GRAPH_RAG_TOP_K=5
GRAPH_RAG_ITERATIONS=2
GRAPH_RAG_ITERATION_TOP_K=8
GRAPH_RAG_MAX_QUERY_TERMS=24
GRAPH_RAG_SEMANTIC_WEIGHT=0.65
GRAPH_RAG_CONTROL_WEIGHT=0.35
GRAPH_RAG_ADAPTIVE_STOP_ENABLED=true
GRAPH_RAG_ADAPTIVE_MIN_GAIN=0.08
GRAPH_RAG_ADAPTIVE_MIN_NEW_NODES=1
GRAPH_RAG_ADAPTIVE_STABLE_ROUNDS=1
SQL_SANDBOX_ENABLED=true
SQL_SANDBOX_MAX_STATEMENTS=8

EXCEL_BOOTSTRAP_ENABLED=true
EXCEL_FILE_PATH=../electronic_component_data.xlsx

LLM_ENABLED=true
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-api-key
LLM_MODEL=qwen2.5-coder-7b-instruct
LLM_TIMEOUT_S=60
LLM_TEMPERATURE=0.1
LLM_USE_FOR_SAFE_AGENT=true
